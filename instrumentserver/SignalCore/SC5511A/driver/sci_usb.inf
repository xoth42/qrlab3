SC5321A_DeviceName="SC5321A KuKa IQ Demodulator"
SC5360A_DeviceName="SC5360A RF Downconverter"
SC5360B_DeviceName="SC5360B RF Downconverter"

; Upconverters
SC5406A_DeviceName="SC5406A RF Upconverter"
SC5406B_DeviceName="SC5406B RF Upconverter"
SC5408A_DeviceName="SC5408A RF Upconverter"
SC5413A_DeviceName="SC5413A RF IQ Modulator"
SC5421A_DeviceName="SC5421A KuKa IQ Modulator"

; Sources
SC5501A_DeviceName="SC5501A Signal Source"
SC5503A_DeviceName="SC5503A Signal Source"
SC5503B_DeviceName="SC5503B Signal Source"
SC5506A_DeviceName="SC5506A Signal Source"
