; ======== SCI_USB libusb 1.0 (WinUSB) device driver ==========

; =================== Strings ===================
[Strings]
ManufacturerName="SignalCore Inc"
ClassName="SignalCore USB Devices"
InstallDisk="SCI_USB Installation Disk"
WinUsb_SvcDesc="SignalCore -WinUSB- Driver"
DisplayClassName="SignalCore USB Devices"

; Downconverters
SC5303A_DeviceName="SC5303A RF Downconverter"
SC5306A_DeviceName="SC5306A RF Downconverter"
SC5306B_DeviceName="SC5306B RF Downconverter"
SC5308A_DeviceName="SC5308A RF Downconverter"
