SC5513B_DeviceName="SC5513B ULP Signal Source"
SC5513C_DeviceName="SC5513C ULP Signal Source"
SC800_DeviceName="SC800 NanoSynth Signal Source"

[Version]
Signature = $WINDOWS NT$
Class=%ClassName%
ClassGuid={45918F51-1F0E-4F26-99DF-5B83E089192D}
Provider = %ManufacturerName%
CatalogFile=sci_usb.cat
DriverVer=01/03/2018,2.0.1.0
 
[ClassInstall32]
AddReg=CustomClassAddReg

[CustomClassAddReg]
HKR,,,,%DisplayClassName%
HKR,,Icon,,-20

