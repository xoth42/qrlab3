# .env.example — copy to .env (repo root) to enable.
#
# Read by lib/server_support/uselogs.py to set per-logger levels in the
# instrument server processes (instrument_server.py, instruments_server.py)
# without editing code. Format: LOG_<logger_name>=<LEVEL>.
#
# <logger_name> is the Python logger's __name__:
#   - "DEFAULT" is special-cased to mean the root logger.
#   - Instrument plugins use their bare module name, e.g. "Keysight_DIG",
#     because instrument_server.py imports them via `__import__(instype)`
#     with instrument_plugins/ on sys.path (no package prefix).
#   - Modules imported normally (e.g. via `lib.server_support.lifeline`)
#     keep their dotted path as the logger name.
#   - Scripts run directly (python foo.py) get the logger name "__main__".
#
# <LEVEL> is any of: DEBUG, INFO, WARNING, ERROR, CRITICAL (case-insensitive).
#
# Precedence: a real environment variable of the same name overrides the
# value here, e.g. `LOG_Keysight_DIG=DEBUG python instrument_server.py`
# works without touching this file.
#
# A real .env should NOT be committed (already in .gitignore) since it's
# meant to reflect your local debugging session, not shared defaults.

# --- Global default -----------------------------------------------------
# Root logger level. Most modules that don't have their own LOG_<name>
# entry below inherit this.
LOG_DEFAULT=INFO

# --- Digitizer / AWG plugins (instrumentserver/instrument_plugins/) ----
# Turn on DEBUG here to see the _log_status() dig.getStatus() calls added
# around arm()/start_hvi()/take_avg_shot(), plus all the other logger.debug()
# diagnostics already in Keysight_DIG.py (set_demod, demod reshaping, etc).
LOG_Keysight_DIG=DEBUG
LOG_Keysight_AWG=INFO
LOG_CompiledHVI=INFO
LOG_Alazar_Daemon=INFO

# --- Sequencer / waveform loading ---------------------------------------
LOG_awgloader=INFO
LOG_pulseseq.sequencer=INFO
LOG_pulseseq.pulselib=WARNING

# --- Server lifecycle / process management ------------------------------
LOG_lib.server_support.lifeline=INFO
LOG_pythonprocess=INFO
LOG_objectsharer.objectsharer=WARNING

# --- Measurement / sweep scripts -----------------------------------------
# These run as `python scripts/...py`, so their logger name is "__main__",
# not the file name. Only one __main__ entry makes sense per process.
LOG___main__=DEBUG

# --- Demodulation math ----------------------------------------------------
LOG_lib.math.demod=WARNING

# --- Noisy third-party libraries you usually want quiet -------------------
LOG_matplotlib=WARNING
LOG_PyQt5=WARNING
